{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/ruff_lint.py 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Linting with ruff..."
          }
        ]
      }
    ]
  }
}
